{
  "expo": {
    "name": "Mobile Wash",
    "slug": "mobilewash",
    "owner": "mobile-wash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mobilewash",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobilewash.app",
      "buildNumber": "11",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "近くのプロを表示するために位置情報を使用します",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "出張中の位置情報共有に使用します",
        "NSUserTrackingUsageDescription": "パーソナライズされた広告を表示するために使用します",
        "NSCameraUsageDescription": "プロフィール写真の撮影、施工写真の記録、決済時のカード読み取りに使用します",
        "NSPhotoLibraryUsageDescription": "プロフィール写真や施工写真を選択するためにフォトライブラリにアクセスします",
        "NSPhotoLibraryAddUsageDescription": "施工後の写真をフォトライブラリに保存するために使用します",
        "NSMicrophoneUsageDescription": "チャット時の音声メッセージや動画撮影でマイクを使用します",
        "ITSAppUsesNonExemptEncryption": false,
        "SKAdNetworkItems": [
          { "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork" }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.mobilewash.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-location",
      "expo-secure-store",
      "expo-notifications",
      "./plugins/with-splashscreen-logo.js",
      "./plugins/with-android-emulator-support.js"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b9ac78a6-8899-44d3-a725-59af14bfae88"
      }
    }
  }
}
