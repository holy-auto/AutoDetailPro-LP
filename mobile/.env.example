EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key

# ============================================================================
# Supabase Dashboard 設定 (Authentication > URL Configuration > Redirect URLs)
# 以下を追加してください (PKCE flow / expo-auth-session の deep link 用):
#   mobilewash://auth/callback
#   exp://127.0.0.1:8081/--/auth/callback   (Expo Go ローカル開発用)
# ============================================================================

# ============================================================================
# !!! 重要 !!! EAS Build (TestFlight / Play / 内部配布) でのログイン
# ----------------------------------------------------------------------------
# .env ファイルは EAS Build に含まれません (gitignore 対象)。
# このため EAS でビルドしたアプリは EXPO_PUBLIC_* がすべて空となり、
# Supabase クライアントがデモモードに入って Apple/Google ログインが
# 必ず失敗します。
#
# 解決方法: EAS の環境変数機能で各 EXPO_PUBLIC_* を登録する。
#
# プロジェクトに対して設定 (development / preview / production を 3 回ずつ):
#
#   eas env:create --environment production --name EXPO_PUBLIC_SUPABASE_URL \
#     --value "https://your-project.supabase.co" --visibility plaintext
#
#   eas env:create --environment production --name EXPO_PUBLIC_SUPABASE_ANON_KEY \
#     --value "eyJhbGci..." --visibility plaintext
#
#   eas env:create --environment production --name EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY \
#     --value "pk_live_..." --visibility plaintext
#
#   # ...同様に GOOGLE_* MAPS_API_KEY も登録
#
# preview / development も同様に登録 (--environment preview / development)。
# 一度登録すれば eas build のたびに自動で env に注入されます。
#
# 確認: eas env:list --environment production
# ============================================================================
