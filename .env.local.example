# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 任意: 集計用にサービスロールキーも設定するとRLSをバイパスして
# count を取得できます（src/lib/stats.ts が利用）。
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase SQL — テーブル作成
#
# -- 一般ユーザー事前登録（メールアドレスのみ）
# CREATE TABLE waitlist (
#   id BIGSERIAL PRIMARY KEY,
#   email TEXT UNIQUE NOT NULL,
#   created_at TIMESTAMPTZ DEFAULT NOW()
# );
#
# -- 認定プロ事前登録（プロフィール情報あり）
# CREATE TABLE pros (
#   id BIGSERIAL PRIMARY KEY,
#   email TEXT UNIQUE NOT NULL,
#   name TEXT,
#   phone TEXT,
#   area TEXT,                      -- prefecture slug (tokyo, osaka, etc.)
#   experience_years TEXT,          -- beginner, 1-3, 3-5, 5-10, 10+
#   services TEXT[],                -- 得意メニューの配列
#   message TEXT,
#   status TEXT DEFAULT 'pending',  -- pending, contacted, approved, rejected
#   created_at TIMESTAMPTZ DEFAULT NOW()
# );
#
# -- アプリインストール集計（Firebase Analytics 等から書き込み）
# CREATE TABLE app_installs (
#   id BIGSERIAL PRIMARY KEY,
#   platform TEXT,                  -- ios, android
#   installed_at TIMESTAMPTZ DEFAULT NOW()
# );
#
# -- 施工予約（ローンチ後に使用）
# CREATE TABLE bookings (
#   id BIGSERIAL PRIMARY KEY,
#   created_at TIMESTAMPTZ DEFAULT NOW()
# );
#
# -- RLS ポリシー: 匿名ユーザーから INSERT のみ許可、SELECT は service_role のみ
# ALTER TABLE waitlist ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "anon insert waitlist" ON waitlist
#   FOR INSERT TO anon WITH CHECK (true);
#
# ALTER TABLE pros ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "anon insert pros" ON pros
#   FOR INSERT TO anon WITH CHECK (true);

